patch_file=
stashed_untracked=0

restore_worktree() {
	status=$?
	if [ "$stashed_untracked" = "1" ]; then
		if ! git stash pop --quiet; then
			echo "husky - failed to restore untracked changes; backup stash kept" >&2
			exit 1
		fi
	fi
	if [ -n "$patch_file" ] && [ -s "$patch_file" ]; then
		if ! git apply --whitespace=nowarn "$patch_file"; then
			echo "husky - failed to restore unstaged changes from $patch_file" >&2
			exit 1
		fi
	fi
	if [ -n "$patch_file" ]; then
		rm -f "$patch_file"
	fi
	exit "$status"
}

if ! git diff --quiet; then
	patch_file="${TMPDIR:-/tmp}/husky-staged-check-$$.patch"
	git diff --binary > "$patch_file"
	trap restore_worktree EXIT INT HUP TERM
	git restore --worktree .
fi

if [ -n "$(git ls-files --others --exclude-standard)" ]; then
	trap restore_worktree EXIT INT HUP TERM
	git stash push --quiet --keep-index --include-untracked \
		-m "husky untracked-check backup"
	stashed_untracked=1
fi

pnpm check
